{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "quoteProps": "as-needed",
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "ignorePatterns": [
    "**/*-method-action-types.ts",
    ".yarnrc.yml",
    "merged-packages/**",
    "CHANGELOG.md"
  ]
}
