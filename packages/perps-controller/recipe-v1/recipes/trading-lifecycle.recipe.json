{
  "schema_version": 1,
  "title": "Perps controller trading-lifecycle verification (headless, no UI)",
  "description": "Calls PerpsController.placeOrder, updatePositionTPSL, and closePosition through a headless in-memory provider. No wallet, no UI, no direct HyperLiquid script.",
  "proofTargets": [
    {
      "id": "trading-lifecycle",
      "claim": "PerpsController trading methods can orchestrate open, TP/SL, and close calls through the controller/service/provider path."
    }
  ],
  "validate": {
    "workflow": {
      "entry": "place-order",
      "nodes": {
        "place-order": {
          "action": "perps_controller.call",
          "method": "placeOrder",
          "params": {
            "symbol": "BTC",
            "isBuy": true,
            "size": "0.01",
            "orderType": "market",
            "currentPrice": 50000,
            "leverage": 10
          },
          "next": "assert-open-success",
          "proofTarget": "trading-lifecycle"
        },
        "assert-open-success": {
          "action": "assert_json",
          "source": "place-order",
          "path": "success",
          "equals": true,
          "next": "update-tpsl"
        },
        "update-tpsl": {
          "action": "perps_controller.call",
          "method": "updatePositionTPSL",
          "params": {
            "symbol": "BTC",
            "takeProfitPrice": "55000",
            "stopLossPrice": "47500",
            "trackingData": {
              "direction": "long",
              "source": "recipe_headless",
              "positionSize": 0.01,
              "takeProfitPercentage": 10,
              "stopLossPercentage": 5,
              "isEditingExistingPosition": false,
              "entryPrice": 50000
            }
          },
          "next": "assert-tpsl-success"
        },
        "assert-tpsl-success": {
          "action": "assert_json",
          "source": "update-tpsl",
          "path": "success",
          "equals": true,
          "next": "close-position"
        },
        "close-position": {
          "action": "perps_controller.call",
          "method": "closePosition",
          "params": {
            "symbol": "BTC",
            "size": "0.01",
            "orderType": "market",
            "currentPrice": 50100
          },
          "next": "assert-close-success"
        },
        "assert-close-success": {
          "action": "assert_json",
          "source": "close-position",
          "path": "success",
          "equals": true,
          "next": "done"
        },
        "done": { "action": "end", "status": "pass" }
      }
    }
  }
}
