{
  "schema_version": 1,
  "title": "E2E: Full perps controller validation",
  "description": "Runs all perps e2e scenarios: market data, account state, order validation, WebSocket stream, error codes.",
  "validate": {
    "workflow": {
      "entry": "market-data",
      "nodes": {
        "market-data": {
          "action": "command",
          "cmd": "cd packages/perps-controller && npx tsx e2e/market-data.ts 2>&1",
          "next": "account-state",
          "intent": "Run the market-data validation scenario"
        },
        "account-state": {
          "action": "command",
          "cmd": "cd packages/perps-controller && npx tsx e2e/account-state.ts 2>&1",
          "next": "order-validation",
          "intent": "Run the account-state validation scenario"
        },
        "order-validation": {
          "action": "command",
          "cmd": "cd packages/perps-controller && npx tsx e2e/order-validation.ts 2>&1",
          "next": "subscription-stream",
          "intent": "Run the order-validation scenario"
        },
        "subscription-stream": {
          "action": "command",
          "cmd": "cd packages/perps-controller && npx tsx e2e/subscription-stream.ts 2>&1",
          "next": "error-codes",
          "intent": "Run the WebSocket subscription scenario"
        },
        "error-codes": {
          "action": "command",
          "cmd": "cd packages/perps-controller && npx tsx e2e/error-codes.ts 2>&1",
          "next": "done",
          "intent": "Run the error-code edge-case scenario"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
