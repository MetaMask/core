{
  "schema_version": 1,
  "title": "E2E: Market data from HyperLiquid",
  "description": "Fetches real market metadata, prices, and spot info from HyperLiquid mainnet. Validates structure and sanity.",
  "validate": {
    "workflow": {
      "entry": "run-market-data",
      "nodes": {
        "run-market-data": {
          "action": "command",
          "cmd": "cd packages/perps-controller && npx tsx e2e/market-data.ts 2>&1",
          "next": "check-pass",
          "intent": "Fetch markets, prices, spotMeta from HyperLiquid"
        },
        "check-pass": {
          "action": "assert_stdout",
          "source": "run-market-data",
          "json_path": "$.status",
          "expected": "pass",
          "next": "done",
          "intent": "All market data assertions passed"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
